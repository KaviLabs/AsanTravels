RewriteEngine On

# Force HTTPS for all traffic (Handles Cloudflare & Reverse Proxies)
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ----------------------------------------------------------------------
# Clean URLs (Hide .html and .php extensions)
# ----------------------------------------------------------------------
# Externally redirect direct requests for .html and .php to extensionless URLs
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^.]+)\.(html|php) [NC]
# Exclude admin and index files from this strict cosmetic redirect to avoid issues
RewriteCond %{REQUEST_URI} !^/index1\.php$
RewriteCond %{REQUEST_URI} !^/asn_.*\.php$
RewriteCond %{REQUEST_URI} !^/admin\.php$
RewriteRule ^ %1 [R=301,L]

# Internally map extensionless URLs to .php files if they exist
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.php -f
RewriteRule ^(.+?)/?$ /$1.php [L]

# Internally map extensionless URLs to .html files if they exist
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ /$1.html [L]

# ----------------------------------------------------------------------
# 1. Rules for asanadmin.xo.je
# ----------------------------------------------------------------------
# If accessing the admin domain, root requests go directly to the login page
RewriteCond %{HTTP_HOST} ^(www\.)?asanadmin\.xo\.je$ [NC]
RewriteRule ^$ asn_admin_loging.php [L]

# Redirect public site pages to the login page on the admin domain
RewriteCond %{HTTP_HOST} ^(www\.)?asanadmin\.xo\.je$ [NC]
RewriteRule ^(index1\.php|about\.html|blog\.html|booking\.html|contact\.html|contact\.php|destination\.html|packages\.html|tour\.html|Custom_Packages\.html|thank_you-booking\.html|thank_you-booking\.php|thank_you-s\.html|thank_you\.html)$ /asn_admin_loging.php [R=301,L]

# ----------------------------------------------------------------------
# 2. Rules for asantravels.lk (and other non-admin requests)
# ----------------------------------------------------------------------
# Root requests to the website domain go to index1.php
RewriteCond %{HTTP_HOST} ^(www\.)?asantravels\.lk$ [NC]
RewriteRule ^$ index1.php [L]

# Block access to the admin files and templates on the website domain
RewriteCond %{HTTP_HOST} ^(www\.)?asantravels\.lk$ [NC]
RewriteRule ^(admin\.php|admin\.html|asn_admin_loging\.php|asn_custom_admin\.php|admin_bookings\.php|asn_Bookings\.php|asn_Contact\.php|asn_Gallery\.php|asn_Reviews\.php|asn_subscribers\.php|asn_galary\.php|logout\.php) - [F,L]
